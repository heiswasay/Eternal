rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['productSlug', 'initials', 'city', 'rating', 'desc', 'orderNo', 'createdAt'])
        && data.keys().size() == 7
        && data.productSlug is string && data.productSlug.size() <= 100
        && data.initials is string && data.initials.size() <= 50
        && data.city is string && data.city.size() <= 50
        && data.rating >= 1 && data.rating <= 5
        && data.desc is string && data.desc.size() <= 1000
        && data.orderNo is string && data.orderNo.size() <= 50
        && data.createdAt == request.time;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['orderId', 'customerName', 'customerPhone', 'customerEmail', 'customerAddress', 'items', 'totalPrice', 'paymentMethod', 'notes', 'status', 'createdAt'])
        && data.keys().size() == 11
        && data.orderId is string && data.orderId.size() <= 100
        && data.customerName is string && data.customerName.size() <= 100
        && data.customerPhone is string && data.customerPhone.size() <= 50
        && data.customerEmail is string && data.customerEmail.size() <= 100
        && data.customerAddress is string && data.customerAddress.size() <= 500
        && data.items is list && data.items.size() > 0 && data.items.size() <= 20
        && data.totalPrice is string && data.totalPrice.size() <= 50
        && data.paymentMethod is string && data.paymentMethod.size() <= 50
        && data.notes is string && data.notes.size() <= 1000
        && data.status in ['new', 'under process', 'delivered', 'cancel', 'refund', 'exchange']
        && data.createdAt == request.time;
    }

    // Public Reviews collection rules
    match /reviews/{reviewId} {
      allow get, list: if true; // Publicly readable reviews
      allow create: if isValidId(reviewId) && isValidReview(incoming());
      allow update, delete: if false; // Reviews are immortal ledger entries and cannot be modified or deleted by clients
    }

    // Secure Orders collection rules
    match /orders/{orderId} {
      allow get, list: if true; // The admin portal at /admin queries this collection
      allow create: if isValidId(orderId) && isValidOrder(incoming());
      // Admin only modifies state status
      allow update: if isValidId(orderId) 
        && incoming().status in ['new', 'under process', 'delivered', 'cancel', 'refund', 'exchange'];
      allow delete: if false; // Deletes strictly prohibited
    }
  }
}
