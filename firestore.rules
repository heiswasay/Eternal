rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net: default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function isValidReview(data) {
      return data.keys().hasAll(['productSlug', 'initials', 'city', 'rating', 'desc', 'orderNo', 'createdAt'])
        && data.keys().size() == 7
        && data.productSlug is string && data.productSlug.size() <= 100
        && data.initials is string && data.initials.size() <= 50
        && data.city is string && data.city.size() <= 50
        && data.rating is int && data.rating >= 1 && data.rating <= 5
        && data.desc is string && data.desc.size() <= 1000
        && data.orderNo is string && data.orderNo.size() <= 50
        && data.createdAt == request.time;
    }

    // Public Reviews collection rules
    match /reviews/{reviewId} {
      allow get, list: if true; // Publicly readable reviews
      allow create: if isValidId(reviewId) && isValidReview(incoming());
      allow update, delete: if false; // Reviews are immortal ledger entries and cannot be modified or deleted by clients
    }

    // Products inventory collection rules
    match /products/{productId} {
      allow get, list: if true; // Publicly readable products
      allow create, update, delete: if true; // Managed by the admin panel
    }
  }
}
