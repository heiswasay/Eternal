{
  "entities": {
    "Review": {
      "title": "Product Review",
      "description": "An authentic purchase testimonial recorded by a customer",
      "type": "object",
      "properties": {
        "productSlug": {
          "type": "string",
          "description": "Identifier for the specific shoe/product model"
        },
        "initials": {
          "type": "string",
          "description": "Initials or name of the reviewer"
        },
        "city": {
          "type": "string",
          "description": "City of residence in Pakistan"
        },
        "rating": {
          "type": "integer",
          "description": "Numeric rating out of 5 stars"
        },
        "desc": {
          "type": "string",
          "description": "Narrative detailing the customer's purchase experience"
        },
        "orderNo": {
          "type": "string",
          "description": "Identifier for the verified purchase of 1 Pair"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the review was registered"
        }
      },
      "required": [
        "productSlug",
        "initials",
        "city",
        "rating",
        "desc",
        "orderNo",
        "createdAt"
      ]
    },
    "Product": {
      "title": "Product Item",
      "description": "A fine footwear product available for purchase in the store",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Full display name of the item"
        },
        "price": {
          "type": "string",
          "description": "Current active selling price"
        },
        "originalPrice": {
          "type": "string",
          "description": "Original non-discounted price (optional)"
        },
        "discountPercent": {
          "type": "string",
          "description": "Percentage or promo offer badge (e.g. 15% OFF) (optional)"
        },
        "image": {
          "type": "string",
          "description": "Primary display image URL"
        },
        "images": {
          "type": "array",
          "description": "All gallery image URLs"
        },
        "category": {
          "type": "string",
          "description": "General style category (e.g. Hand Made)"
        },
        "slug": {
          "type": "string",
          "description": "URL friendly distinct string"
        },
        "description": {
          "type": "string",
          "description": "Sartorial overview explaining design nuance"
        },
        "specs": {
          "type": "object",
          "description": "Anatomy design specs and details"
        }
      },
      "required": [
        "name",
        "price",
        "image",
        "category",
        "slug",
        "description",
        "specs"
      ]
    },
    "AnalyticsEvent": {
      "title": "Analytics Event",
      "description": "Secure record of client-side interaction trace",
      "type": "object",
      "properties": {
        "eventType": {
          "type": "string",
          "enum": ["page_view", "add_to_cart", "click"]
        },
        "path": {
          "type": "string"
        },
        "productSlug": {
          "type": "string"
        },
        "productName": {
          "type": "string"
        },
        "price": {
          "type": "number"
        },
        "size": {
          "type": "string"
        },
        "elementId": {
          "type": "string"
        },
        "elementText": {
          "type": "string"
        },
        "tagName": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["eventType", "createdAt"]
    }
  },
  "firestore": {
    "reviews/{reviewId}": {
      "schema": "Review",
      "description": "Global list of all customer reviews across products"
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "E-commerce inventory catalog items"
    },
    "analytics/{eventId}": {
      "schema": "AnalyticsEvent",
      "description": "Continuous stream of interaction and metrics telemetry"
    }
  }
}
